---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { Sidebar } from '../components/react/Sidebar';
import { AIChatbot } from '../components/react/AIChatbot';
import { Search, Bell } from 'lucide-react';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="bg-neutral-50 antialiased selection:bg-neutral-200 selection:text-neutral-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | La Casa del Bolígrafo</title>
    <!-- ViewTransitions permite navegación ultra-rápida SPA-like -->
    <ViewTransitions />
  </head>
  <body class="flex h-screen overflow-hidden text-neutral-800 bg-gradient-to-br from-neutral-50 to-neutral-100/50">
    
    <!-- Sidebar React con interactividad de colapso -->
    <aside class="h-full z-20 hidden md:block overflow-hidden">
      <!-- Usamos client:load para que la animación y estado interactivas funcionen desde el inicio -->
      <Sidebar client:load currentPath={currentPath} />
    </aside>

    <!-- Contenedor Principal Lado Derecho -->
    <div class="flex-1 flex flex-col h-[100dvh] relative overflow-hidden">
      
      <!-- Topbar -->
      <header class="h-16 border-b border-neutral-200/60 bg-white/80 backdrop-blur-xl flex items-center justify-between px-4 sm:px-6 z-10 shrink-0">
        
        <!-- Controles Móviles Izquierda -->
        <div class="flex items-center gap-3 md:hidden">
          <button id="mobile-menu-open" class="p-2 -ml-2 text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 rounded-xl transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <span class="font-bold text-neutral-900 tracking-tight text-lg">LCB</span>
        </div>

        <!-- Searchbox Visual (Se implementará real más adelante) -->
        <div class="flex-1 max-w-md w-full relative hidden md:block">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-neutral-400">
            <!-- Icono SVG inyectado -->
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <input 
            type="text" 
            placeholder="Buscar productos por ref, nombre..." 
            class="block w-full pl-10 pr-3 py-2 border border-neutral-200 rounded-xl leading-5 bg-neutral-100/50 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-900 focus:border-neutral-900 focus:bg-white sm:text-sm transition-all"
          />
          <div class="absolute inset-y-0 right-0 pr-2 flex items-center">
            <kbd class="inline-flex items-center border border-neutral-200 rounded px-2 text-xs font-sans font-medium text-neutral-400">⌘K</kbd>
          </div>
        </div>

        <!-- Perfil y Notificaciones -->
        <div class="flex items-center gap-3 sm:gap-4 ml-auto">
          <button class="p-2 text-neutral-400 hover:text-neutral-800 hover:bg-neutral-100 rounded-full transition-colors relative hidden sm:block">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
            <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
          </button>
          
          <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-neutral-900 flex items-center justify-center text-white font-bold text-xs sm:text-sm shadow-md cursor-pointer hover:scale-105 transition-transform ring-2 ring-white">
            LB
          </div>
        </div>
      </header>

      <!-- Scrollable Main Content -->
      <main class="flex-1 overflow-y-auto w-full p-4 sm:p-6 lg:p-8 scroll-smooth pb-24 md:pb-8">
        <div class="max-w-6xl mx-auto h-full animate-in fade-in duration-500">
          <slot />
        </div>
      </main>
    </div>

    <!-- Mobile Navigation Drawer Overlay -->
    <div id="mobile-drawer" class="fixed inset-0 z-50 pointer-events-none transition-all duration-300 opacity-0 bg-neutral-900/40 backdrop-blur-sm md:hidden">
      <!-- Contenedor Lateral -->
      <div id="mobile-sidebar-container" class="absolute top-0 left-0 bottom-0 w-[260px] bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 flex flex-col pointer-events-auto">
        <div class="flex items-center justify-between p-4 border-b border-neutral-100">
          <span class="font-black text-lg text-neutral-900 tracking-tight">Menú Principal</span>
          <button id="mobile-menu-close" class="p-2 text-neutral-400 hover:text-neutral-900 hover:bg-neutral-100 rounded-xl transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <!-- Renderizamos una segunda instancia del Sidebar para Mobile forzando ancho completo -->
        <div class="flex-1 overflow-y-auto">
          <Sidebar client:load currentPath={currentPath} />
        </div>
      </div>
    </div>

    <!-- Chatbot flotante global -->
    <AIChatbot client:only="react" />

  </body>
</html>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnOpen = document.getElementById('mobile-menu-open');
    const btnClose = document.getElementById('mobile-menu-close');
    const drawer = document.getElementById('mobile-drawer');
    const container = document.getElementById('mobile-sidebar-container');

    const openDrawer = () => {
      drawer?.classList.remove('pointer-events-none', 'opacity-0');
      container?.classList.remove('-translate-x-full');
    };

    const closeDrawer = () => {
      container?.classList.add('-translate-x-full');
      drawer?.classList.add('opacity-0');
      setTimeout(() => drawer?.classList.add('pointer-events-none'), 300);
    };

    btnOpen?.addEventListener('click', openDrawer);
    btnClose?.addEventListener('click', closeDrawer);
    drawer?.addEventListener('click', (e) => {
      if (e.target === drawer) closeDrawer();
    });
  });
</script>
